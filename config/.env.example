# ===========================================
# Multi-Agent Automation System - 环境配置
# 复制为 ~/.hermes/.env 并填入实际值
# ===========================================

# ── 飞书/Lark Gateway ──
# 在 https://open.feishu.cn/ 创建应用获取
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_DOMAIN=https://open.feishu.cn
FEISHU_CONNECTION_MODE=websocket
FEISHU_ALLOW_ALL_USERS=true
FEISHU_GROUP_POLICY=open

# ── 模型提供商 ──
# DeepSeek (主力)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# SiliconFlow (备用 - 推荐)
# SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxx

# Zenmux (兜底 - DeepSeek免费节点)
# ZENMUX_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 推理配置 ──
HERMES_MAX_ITERATIONS=90
